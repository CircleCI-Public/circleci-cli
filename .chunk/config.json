{
  "commands": [
    {
      "name": "test",
      "run": "task test",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 3
    },
    {
      "name": "lint",
      "run": "task lint",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 60,
      "limit": 3
    },
    {
      "name": "format",
      "run": "task fmt",
      "role": "autofix",
      "timeout": 30,
      "limit": 3,
      "always": true
    }
  ]
}
