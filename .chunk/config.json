{
  "commands": [
    {
      "name": "test",
      "run": "task test",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 300,
      "limit": 3,
      "remote": true
    },
    {
      "name": "lint",
      "run": "task lint",
      "role": "gate",
      "fileExt": ".go",
      "timeout": 60,
      "limit": 3,
      "remote": true
    },
    {
      "name": "format",
      "run": "task fmt",
      "role": "autofix",
      "timeout": 30,
      "limit": 3,
      "always": true
    }
  ],
  "validation": {
    "sidecarImage": "3e440dfc-2708-466d-8572-fd64aa411950"
  },
  "environment": {
    "stack": "go",
    "setup": [
      {
        "name": "system",
        "command": "sudo apt-get update \u0026\u0026 sudo apt-get install -y git --no-install-recommends \u0026\u0026 sudo rm -rf /var/lib/apt/lists/*"
      },
      {
        "name": "install",
        "command": "go mod download"
      },
      {
        "name": "test",
        "command": "go test -p 1 ./..."
      }
    ],
    "image": "cimg/go",
    "image_version": "1.26.3"
  }
}
